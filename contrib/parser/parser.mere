let _ = print ("h7  (type payload):   " ++ parse_str_program "type opt = | Just of int | Nothing; Just (42)") in
let _ = print ("h8  (type no lead |): " ++ parse_str_program "type bit = Zero | One; Zero") in
let _ = print ("h9  (pattern let):    " ++ parse_str_program "let (a, b) = (1, 2); a + b") in
let _ = print ("h10 (mix decls):      " ++ parse_str_program "type opt = | Just of int | Nothing; let x = Just (1); let rec f = fn n -> n + 1; f 0") in
let _ = print ("h11 (let in main):    " ++ parse_str_program "let x = 1 in x + 1") in
let _ = print ("h12 (annotated decl): " ++ parse_str_program "let add = fn (x: int) -> fn (y: int) -> x + y; add 1 2") in
let _ = print ("h13 (full program):   " ++ parse_str_program "type mylist = | MyNil | MyCons of int * mylist; let rec sum = fn (xs: mylist) -> match xs with | MyNil -> 0 | MyCons (h, t) -> h + sum t; sum (MyCons (1, MyCons (2, MyCons (3, MyNil))))") in
0

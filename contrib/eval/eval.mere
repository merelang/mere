// contrib/eval — Mere self-hosted evaluator (Phase 51).
// This file: Stage 51a — minimal eval MVP.
//
// Tree-walking interpreter for the Mere AST defined in
// `contrib/parser/ast.mere`. Stage 51a covers literals, variables, the
// binary / comparison / logical operator groups, unary negation, and
// `if`. Subsequent stages add:
//   - 51b: closures (`fn`), `EApp`, `ELet`, `EMatch`, `ELetRec`
//   - 51c: constructors / tuples / list literal reconstruction
//   - 51d: full pattern coverage + records
//   - 51e: minimal builtins (extern fn) + top-level decl integration
//   - 51f: browser bridge — live in-browser Mere REPL
//
// See aidocs/projects/lang/51_self_hosted_eval_paper.md for the full
// multi-stage plan. The AST shape is the same one parser.mere builds
// and fmt.mere consumes (ast.mere is the shared definition).

import "../parser/ast.mere";
// Stage 51e: pull the parser in so we can write `parse_and_eval`. Heavy
// dep, but the alternative (hand-coding ASTs forever) doesn't compose
// with the browser bridge we want for 51f. `lexer.mere` rides along
// transitively through `parser.mere`.
import "../parser/parser.mere";

// === Value representation ==================================================
//
// Immutable variant. Mutable containers (Vec / OwnedVec / Map / StrBuf)
// are deferred — Mere's `fn` is pure and the self-host eval doesn't
// emit any. `VRecord`, `VFloat`, and the mutual-recursion `VRecGroup`
// shape land in later stages.

type value =
  | VInt of int
  | VBool of bool
  | VStr of str
  | VUnit
  | VConstr of str * value option
  | VTuple of value list
  // VClosure carries the captured environment as a list. The OCaml side
  // uses an `env ref` so a `let rec` body can reference itself before
  // the binding is fully built; the self-host uses VRecBinding (below)
  // to keep the env immutable.
  | VClosure of str * expr * (str * value) list
  // Stage 51b-2: placeholder env entry for a `let rec` binding. Stores
  // the binding's own name, the full rec-group bindings list (all
  // mutually-recursive names + their body exprs), and the outer env
  // (the env BEFORE the let rec). `lookup_env` resolves a VRecBinding
  // by rebuilding a fresh "rec env" — each rec-group name re-bound to
  // VRecBinding — and evaluating the binding's body in it. Each
  // resolution allocates a new closure, which is fine; the binding
  // is shared by reference (Mere lists are immutable).
  | VRecBinding of str * (str * expr) list * (str * value) list
  // Stage 51d: record value. Mirrors OCaml-side `V_record (name,
  // fields)` — carries the type name so `value_to_str` can emit
  // `Name { f1 = v1, … }` and `match_pattern`'s `PRecord` branch can
  // assert name equality before matching fields.
  | VRecord of str * (str * value) list
  // Stage 51e: built-in (host-provided) function reference. The value
  // is just a name; `apply_builtin` (in `eval`'s `EApp` arm) dispatches
  // to the OCaml-side primitives via the Mere prelude. Multi-arg
  // builtins aren't supported yet — the MVP set is `print` and `show`.
  | VBuiltin of str
  ;

// === Environment ===========================================================

type env = (str * value) list;

// `lookup_env` lives in the `eval` let-rec chain below — it needs to
// call `eval` to resolve `VRecBinding` placeholders introduced by
// `let rec`. See the chain near the bottom of this file.

// === Debug printing (value -> str) =========================================
//
// Mirrors `Eval.to_string` from OCaml-side `lib/eval.ml`, including
// `[1, 2, 3]` reconstruction over `Cons` / `Nil` chains (Stage 51c).
// A well-formed `Cons (h, t) … Cons (h, Nil)` chain becomes
// `[h, …, h]`; a malformed chain falls back to constructor-syntax
// `Cons (...)`.

// Walk a `Cons` chain. Returns `Some elems` if the chain terminates in
// `Nil` (well-formed list), `None` otherwise.
let rec try_as_list = fn (v: value) ->
  match v with
  | VConstr ("Nil", None) -> Some Nil
  | VConstr ("Cons", Some (VTuple (Cons (h, Cons (t, Nil))))) ->
    (match try_as_list t with
      | None -> None
      | Some rest -> Some (Cons (h, rest)))
  | _ -> None
  ;

let rec value_to_str = fn (v: value) ->
  match v with
  | VInt n -> show n
  | VBool b -> if b then "true" else "false"
  | VStr s -> "\"" ++ s ++ "\""
  | VUnit -> "()"
  | VConstr ("Nil", None) -> "[]"
  | VConstr (name, None) -> name
  | VConstr (name, Some payload) ->
    // If this is a well-formed Cons chain, render as `[e1, e2, ...]`.
    // Otherwise fall back to `Name payload` constructor syntax.
    (match try_as_list v with
      | Some elems ->
        let parts = list_map elems (fn (e: value) -> value_to_str e) in
        "[" ++ str_join ", " parts ++ "]"
      | None -> name ++ " " ++ value_to_str payload)
  | VTuple vs ->
    let parts = list_map vs (fn (v2: value) -> value_to_str v2) in
    "(" ++ str_join ", " parts ++ ")"
  | VClosure _ -> "<closure>"
  | VRecBinding (name, _, _) -> "<rec:" ++ name ++ ">"
  | VRecord (name, fields) ->
    let parts = list_map fields (fn (f: str * value) ->
      let (fname, fv) = f in fname ++ " = " ++ value_to_str fv) in
    name ++ " \{ " ++ str_join ", " parts ++ " }"
  | VBuiltin name -> "<builtin:" ++ name ++ ">"
  ;

// === Pattern matching ======================================================
//
// `match_pattern p v` -> `Some bindings` if `v` matches `p`, `None`
// otherwise. Mirrors OCaml-side `Eval.match_pattern`. The `bindings`
// list shape `(str * value) list` is the same as `env`, so the caller
// can prepend it directly.
//
// `PRecord` is in `ast.mere` but not handled here — `VRecord` doesn't
// exist until Stage 51d. The fall-through `_` arm covers it (no
// match).

let rec match_pattern = fn (p: pattern) -> fn (v: value) ->
  match p with
  | PWild -> Some Nil
  | PVar name -> Some (Cons ((name, v), Nil))
  | PInt n ->
    (match v with
      | VInt m -> if n == m then Some Nil else None
      | _ -> None)
  | PBool b ->
    (match v with
      | VBool b2 -> if b == b2 then Some Nil else None
      | _ -> None)
  | PStr s ->
    (match v with
      | VStr s2 -> if s == s2 then Some Nil else None
      | _ -> None)
  | PUnit ->
    (match v with
      | VUnit -> Some Nil
      | _ -> None)
  | PConstr (cname, sub_p_opt) ->
    (match v with
      | VConstr (vname, sub_v_opt) ->
        if cname == vname then
          (match (sub_p_opt, sub_v_opt) with
            | (None, None) -> Some Nil
            | (Some sub_p, Some sub_v) -> match_pattern sub_p sub_v
            | _ -> None)
        else None
      | _ -> None)
  | PTuple ps ->
    (match v with
      | VTuple vs -> match_pattern_list ps vs
      | _ -> None)
  | PAs (sub_p, name) ->
    (match match_pattern sub_p v with
      | None -> None
      | Some bs -> Some (Cons ((name, v), bs)))
  | POr (p1, p2) ->
    (match match_pattern p1 v with
      | Some bs -> Some bs
      | None -> match_pattern p2 v)
  // Stage 51d: PRecord matches against VRecord with the same type
  // name. The pattern only mentions the subset of fields it cares
  // about; unmentioned fields are ignored.
  | PRecord (name, fpats) ->
    (match v with
      | VRecord (vname, fields) ->
        if name == vname then match_record_fields fpats fields
        else None
      | _ -> None)

and match_record_fields = fn (fpats: (str * pattern) list)
                       -> fn (fields: (str * value) list) ->
  match fpats with
  | Nil -> Some Nil
  | Cons (fp, rest) ->
    let (fname, sub_p) = fp in
    (match lookup_field fname fields with
      | None -> None
      | Some fv ->
        (match match_pattern sub_p fv with
          | None -> None
          | Some bs1 ->
            (match match_record_fields rest fields with
              | None -> None
              | Some bs2 -> Some (concat_bindings bs1 bs2))))

and lookup_field = fn (name: str) -> fn (fields: (str * value) list) ->
  match fields with
  | Nil -> None
  | Cons (f, rest) ->
    let (fname, fv) = f in
    if fname == name then Some fv
    else lookup_field name rest

and match_pattern_list = fn (ps: pattern list) -> fn (vs: value list) ->
  match (ps, vs) with
  | (Nil, Nil) -> Some Nil
  | (Cons (ph, pt), Cons (vh, vt)) ->
    (match match_pattern ph vh with
      | None -> None
      | Some bs1 ->
        (match match_pattern_list pt vt with
          | None -> None
          | Some bs2 -> Some (concat_bindings bs1 bs2)))
  | _ -> None

and concat_bindings = fn (a: (str * value) list) -> fn (b: (str * value) list) ->
  match a with
  | Nil -> b
  | Cons (h, t) -> Cons (h, concat_bindings t b);

// Prepend a list of bindings to an env (left-most binding wins on
// lookup since `lookup_env` is linear-left-to-right).
let rec extend_env = fn (bindings: (str * value) list) -> fn (e: env) ->
  match bindings with
  | Nil -> e
  | Cons (b, rest) -> Cons (b, extend_env rest e);

// === Operator dispatch =====================================================
//
// `eval_binop` / `eval_cmpop` take pre-evaluated `value`s so they don't
// need to know about env or expr. Logical ops aren't here — they need
// short-circuit semantics, so the dispatch lives inline in `eval`.

let eval_binop = fn (op: binop) -> fn (a: value) -> fn (b: value) ->
  match (op, a, b) with
  | (OpAdd, VInt x, VInt y) -> VInt (x + y)
  | (OpSub, VInt x, VInt y) -> VInt (x - y)
  | (OpMul, VInt x, VInt y) -> VInt (x * y)
  | (OpDiv, VInt x, VInt y) -> VInt (x / y)
  | (OpMod, VInt x, VInt y) -> VInt (x % y)
  | (OpConcat, VStr x, VStr y) -> VStr (x ++ y)
  | _ -> fail "binop: type mismatch (stage 51a only handles int / str)"
  ;

let eval_cmpop = fn (op: cmpop) -> fn (a: value) -> fn (b: value) ->
  match (op, a, b) with
  | (OpEq, VInt x, VInt y) -> VBool (x == y)
  | (OpEq, VBool x, VBool y) -> VBool (x == y)
  | (OpEq, VStr x, VStr y) -> VBool (x == y)
  | (OpNe, VInt x, VInt y) -> VBool (x != y)
  | (OpNe, VBool x, VBool y) -> VBool (x != y)
  | (OpNe, VStr x, VStr y) -> VBool (x != y)
  | (OpLt, VInt x, VInt y) -> VBool (x < y)
  | (OpLe, VInt x, VInt y) -> VBool (x <= y)
  | (OpGt, VInt x, VInt y) -> VBool (x > y)
  | (OpGe, VInt x, VInt y) -> VBool (x >= y)
  // Mere's `< <= > >=` are int-only — strings only support `== !=`.
  | _ -> fail "cmpop: type mismatch"
  ;

// === Eval dispatcher =======================================================
//
// Stage 51a scope. Branches not yet handled (`EFun`, `EApp`, `ELet`,
// `ELetRec`, `EMatch`, `EConstr`, `ETuple`, `ERecord*`, `EFieldGet`,
// `EFloat`) fall through to a `fail` that names the stage they unlock.

// Note: the match arm pattern variables avoid shadowing the outer
// `e` parameter — naming an arm-bound inner expression `e` confuses
// the C codegen into looping (it picks the wrong binding and
// `eval e env` recurses on itself, segfaulting). Inner uses `inner` /
// `cond` / etc. instead.
let rec eval = fn (e: expr) -> fn (env: env) ->
  match e with
  | EInt n -> VInt n
  | EBool b -> VBool b
  | EStr s -> VStr s
  | EUnit -> VUnit
  | EVar name -> lookup_env name env
  | EBin (op, a, b) -> eval_binop op (eval a env) (eval b env)
  | ECmp (op, a, b) -> eval_cmpop op (eval a env) (eval b env)
  // `&&` and `||` short-circuit, so the dispatch is inline (don't
  // evaluate the RHS unless needed). Matches OCaml-side semantics.
  | ELogic (OpAnd, a, b) ->
    (match eval a env with
      | VBool false -> VBool false
      | VBool true -> eval b env
      | _ -> fail "&&: expected bool on lhs")
  | ELogic (OpOr, a, b) ->
    (match eval a env with
      | VBool true -> VBool true
      | VBool false -> eval b env
      | _ -> fail "||: expected bool on lhs")
  | ENeg inner ->
    (match eval inner env with
      | VInt n -> VInt (0 - n)
      | _ -> fail "neg: expected int")
  | EIf (cond, then_e, else_e) ->
    (match eval cond env with
      | VBool true -> eval then_e env
      | VBool false -> eval else_e env
      | _ -> fail "if: expected bool condition")
  // EAnnot is transparent at eval — the annotation only matters to the
  // (future) typer.
  | EAnnot (annotated, _ty) -> eval annotated env
  // Stage 51b-1: closures + let + match + constructor / tuple.
  | EFun (arg_name, _ty_opt, body) ->
    VClosure (arg_name, body, env)
  | EApp (f, arg) ->
    let fv = eval f env in
    let av = eval arg env in
    (match fv with
      | VClosure (arg_name, body, captured) ->
        eval body (Cons ((arg_name, av), captured))
      | VBuiltin name -> apply_builtin name av
      | _ -> fail "app: not a closure or builtin")
  | ELet (pat, value_expr, body) ->
    let v = eval value_expr env in
    (match match_pattern pat v with
      | None -> fail "let: pattern mismatch"
      | Some bindings -> eval body (extend_env bindings env))
  | EMatch (scrutinee, arms) ->
    try_match_arms arms (eval scrutinee env) env
  | EConstr (name, payload_expr) ->
    (match payload_expr with
      | None -> VConstr (name, None)
      | Some pe -> VConstr (name, Some (eval pe env)))
  | ETuple exprs ->
    VTuple (list_map exprs (fn (ex: expr) -> eval ex env))
  // Stage 51b-2: `let rec NAME = e (and NAME = e)* in body`. The
  // OCaml side uses `env ref` to create a cycle (each binding's
  // closure references an env that already contains it). The
  // self-host keeps `env` immutable by recording placeholder
  // `VRecBinding` entries that `lookup_env` resolves on demand by
  // re-building the rec env and evaluating the binding body. Mutual
  // recursion falls out for free because all rec-group names are
  // bound to placeholders carrying the SAME bindings list.
  | ELetRec (bindings, body) ->
    let rec_env = make_rec_env bindings env in
    eval body rec_env
  // Stage 51d: records.
  | ERecordLit (name, field_exprs) ->
    let field_vals = list_map field_exprs (fn (f: str * expr) ->
      let (fname, fexpr) = f in (fname, eval fexpr env)) in
    VRecord (name, field_vals)
  | EFieldGet (record_expr, fname) ->
    (match eval record_expr env with
      | VRecord (_, fields) ->
        (match lookup_field fname fields with
          | Some v -> v
          | None -> fail ("field not found: " ++ fname))
      | _ -> fail "field access: expected record")
  | ERecordUpdate (base_expr, updates) ->
    (match eval base_expr env with
      | VRecord (rname, fields) ->
        let update_vals = list_map updates (fn (u: str * expr) ->
          let (uname, uexpr) = u in (uname, eval uexpr env)) in
        VRecord (rname, apply_record_updates fields update_vals)
      | _ -> fail "record update: expected record on LHS")
  | _ -> fail "eval: EFloat (or unparseable expression)"

// `EMatch` arm iteration. For each arm, try `match_pattern`; if it
// matches and the optional guard evaluates to `VBool true`, eval the
// body. Otherwise move on. Crashes if no arm matches — mirrors the
// OCaml side's "Match_failure"-style exit but with a single `fail`.
and try_match_arms = fn (arms: (pattern * expr option * expr) list)
                    -> fn (v: value) -> fn (env: env) ->
  match arms with
  | Nil -> fail "match: no arm matched"
  | Cons (arm, rest) ->
    let (pat, guard_opt, body) = arm in
    (match match_pattern pat v with
      | None -> try_match_arms rest v env
      | Some bindings ->
        let arm_env = extend_env bindings env in
        let guard_ok = (match guard_opt with
          | None -> true
          | Some g ->
            (match eval g arm_env with
              | VBool b -> b
              | _ -> fail "match guard: expected bool")) in
        if guard_ok then eval body arm_env
        else try_match_arms rest v env)

// Lookup a name in env. When the entry is a `VRecBinding` (placeholder
// introduced by `let rec`), resolve it on-the-fly: build a fresh rec
// env (each rec-group name re-bound to VRecBinding) and evaluate the
// binding's body in it. The body is typically `EFun`, so resolution
// yields a `VClosure` whose captured env IS the rec env — meaning
// recursive calls inside the body find the rec names via the same
// resolution path.
and lookup_env = fn (name: str) -> fn (e: env) ->
  match e with
  | Nil -> fail ("unbound variable: " ++ name)
  | Cons (b, rest) ->
    let (n, v) = b in
    if n == name then
      (match v with
        | VRecBinding (bname, bindings, outer) ->
          let body = find_rec_body bname bindings in
          let rec_env = make_rec_env bindings outer in
          eval body rec_env
        | _ -> v)
    else lookup_env name rest

// Build the rec env: each binding name maps to `VRecBinding`,
// prepended to the outer env. All placeholders point at the SAME full
// bindings list (not a shrinking tail), so mutual recursion works:
// when `odd` is resolved, the rec env it builds still contains `even`.
and make_rec_env = fn (bindings: (str * expr) list) -> fn (outer: env) ->
  make_rec_env_loop bindings bindings outer

// `all_bindings` is the full rec-group; `remaining` shrinks each step
// only to drive the iteration. Each VRecBinding records `all_bindings`
// so resolution still sees every group member.
and make_rec_env_loop = fn (all_bindings: (str * expr) list)
                     -> fn (remaining: (str * expr) list)
                     -> fn (outer: env) ->
  match remaining with
  | Nil -> outer
  | Cons (b, rest) ->
    let (name, _body) = b in
    Cons ((name, VRecBinding (name, all_bindings, outer)),
          make_rec_env_loop all_bindings rest outer)

and find_rec_body = fn (name: str) -> fn (bindings: (str * expr) list) ->
  match bindings with
  | Nil -> fail ("rec body not found: " ++ name)
  | Cons (b, rest) ->
    let (n, body) = b in
    if n == name then body
    else find_rec_body name rest

// `{ base | f1 = e1, f2 = e2 }` keeps the field order of the base
// record. For each base field, if an update overrides it, use the new
// value; otherwise keep the original. Unknown update keys are silently
// ignored — the OCaml side relies on the typer to reject them, and
// the self-host eval is post-typer (or pre-typer-aware MVP).
and apply_record_updates = fn (base: (str * value) list)
                        -> fn (updates: (str * value) list) ->
  match base with
  | Nil -> Nil
  | Cons (f, rest) ->
    let (fname, fval) = f in
    let new_val = (match lookup_field fname updates with
      | Some v -> v
      | None -> fval) in
    Cons ((fname, new_val), apply_record_updates rest updates)

// Dispatch a host-provided builtin by name. Calls the Mere prelude's
// own builtins under the hood — `print` is the prelude's `print`,
// `show` is the prelude's `show`. The MVP set is small; multi-arg
// builtins (`str_concat`, `list_map`, ...) require partial application
// machinery and ride on a future slice. Most useful work flows
// through `EBin OpConcat` / `ECmp` / `ELogic` / `EApp VClosure`
// anyway, so this minimal builtin set takes us a long way.
and apply_builtin = fn (name: str) -> fn (v: value) ->
  if name == "print" then
    (match v with
      | VStr s -> let _ = print s in VUnit
      | _ -> fail "print: expected str")
  else if name == "show" then
    VStr (value_to_str v)
  else fail ("unknown builtin: " ++ name)
  ;

// === Top-level + builtins ==================================================
//
// `initial_env` seeds the evaluator with host-provided builtin
// references. The user's source can call `print` / `show` directly;
// `eval`'s `EApp` arm dispatches via `apply_builtin`.

let initial_env =
  (Cons (("print", VBuiltin "print"),
   Cons (("show", VBuiltin "show"),
   Nil)) : env);

// Apply one top-level decl, returning the updated env. Type decls
// (`TopType` / `TopRecord` / `TopTypeAlias`) carry no runtime
// information and are no-ops here — the parser already grouped them
// into the program shape, and constructors flow through the AST as
// `EConstr` nodes.
let apply_decl = fn (d: top_decl) -> fn (env: env) ->
  match d with
  | TopLet (pat, e) ->
    let v = eval e env in
    (match match_pattern pat v with
      | None -> fail "TopLet: pattern mismatch"
      | Some bs -> extend_env bs env)
  | TopLetRec bindings -> make_rec_env bindings env
  | TopType _ -> env
  | TopRecord _ -> env
  | TopTypeAlias _ -> env
  ;

let rec apply_decls = fn (decls: top_decl list) -> fn (env: env) ->
  match decls with
  | Nil -> env
  | Cons (d, rest) -> apply_decls rest (apply_decl d env)
  ;

// Run a parsed program. Threads decls through the env left-to-right
// (with TopLetRec opening a rec-group), then evaluates `main` in the
// final env.
let run_program = fn (p: program) ->
  let (decls, main_expr) = p in
  let final_env = apply_decls decls initial_env in
  eval main_expr final_env;

// End-to-end convenience: source string -> evaluated value. Uses the
// imported `tokenize` + `parse_decls` from `contrib/parser`.
let parse_and_eval = fn (src: str) ->
  let toks = tokenize src in
  let (prog, _rest) = parse_decls Nil toks in
  run_program prog;

// === Demos =================================================================
//
// Hand-coded AST literals for now. Once parse + eval are wired together
// (Stage 51e), the demos can be source strings driven through
// tokenize + parse_decls.

// `Nil : env` keeps the binding monomorphic (`env`) instead of
// generalizing to `'a list`, which the C codegen can't monomorphize at
// a top-level value position.
let empty_env = (Nil : env);

// d1: `42`
let d1 = EInt 42;
// d2: `1 + 2`
let d2 = EBin (OpAdd, EInt 1, EInt 2);
// d3: `3 * (4 + 5)`
let d3 = EBin (OpMul, EInt 3, EBin (OpAdd, EInt 4, EInt 5));
// d4: `if 1 < 2 then "less" else "not less"`
let d4 = EIf (ECmp (OpLt, EInt 1, EInt 2),
              EStr "less",
              EStr "not less");
// d5: `-5`
let d5 = ENeg (EInt 5);
// d6: `true && false`
let d6 = ELogic (OpAnd, EBool true, EBool false);
// d7: `1 == 1 || false`
let d7 = ELogic (OpOr,
                 ECmp (OpEq, EInt 1, EInt 1),
                 EBool false);
// d8: `"hello, " ++ "world"`
let d8 = EBin (OpConcat, EStr "hello, ", EStr "world");
// d9: with env { x = 10, y = 20 }, evaluate `x + y` -> 30
let env_xy = Cons (("x", VInt 10), Cons (("y", VInt 20), Nil));
let d9_expr = EBin (OpAdd, EVar "x", EVar "y");
// d10: nested precedence — `if x > 0 then x else -x` with env { x = -7 }
let env_neg = Cons (("x", VInt (0 - 7)), Nil);
let d10_expr =
  EIf (ECmp (OpGt, EVar "x", EInt 0), EVar "x", ENeg (EVar "x"));
// d11: short-circuit — `false && (1/0)` should NOT crash on div-by-zero
// because the lhs is false and we never evaluate the rhs. Verifies the
// inline ELogic dispatch is actually short-circuiting.
let d11 = ELogic (OpAnd,
                  EBool false,
                  EBin (OpDiv, EInt 1, EInt 0));

// === Stage 51b-1 demo data =================================================

// e1: `let x = 5 in x + 1` -> VInt 6
let e1 = ELet (PVar "x", EInt 5,
               EBin (OpAdd, EVar "x", EInt 1));
// e2: `(fn x -> x + 1) 5` -> VInt 6
let e2 = EApp (EFun ("x", None, EBin (OpAdd, EVar "x", EInt 1)),
               EInt 5);
// e3: closure capture — `let y = 10 in (fn x -> x + y) 3` -> VInt 13
let e3 = ELet (PVar "y", EInt 10,
               EApp (EFun ("x", None, EBin (OpAdd, EVar "x", EVar "y")),
                     EInt 3));
// e4: `let inc = fn x -> x + 1 in inc (inc 10)` -> VInt 12
let e4 = ELet (PVar "inc",
               EFun ("x", None, EBin (OpAdd, EVar "x", EInt 1)),
               EApp (EVar "inc",
                     EApp (EVar "inc", EInt 10)));
// e5: `match 0 with | 0 -> "zero" | _ -> "other"` -> "zero"
let e5 = EMatch (EInt 0,
                 Cons ((PInt 0, None, EStr "zero"),
                   Cons ((PWild, None, EStr "other"), Nil)));
// e6: tuple destructure — `let (a, b) = (3, 4) in a + b` -> VInt 7
let e6 = ELet (PTuple (Cons (PVar "a", Cons (PVar "b", Nil))),
               ETuple (Cons (EInt 3, Cons (EInt 4, Nil))),
               EBin (OpAdd, EVar "a", EVar "b"));
// e7: constructor + match — `match Some(42) with | Some n -> n | None -> 0` -> 42
let e7 = EMatch (EConstr ("Some", Some (EInt 42)),
                 Cons ((PConstr ("Some", Some (PVar "n")), None, EVar "n"),
                   Cons ((PConstr ("None", None), None, EInt 0), Nil)));
// e8: as-pattern — `match 5 with | n as x -> n + x` -> 10
let e8 = EMatch (EInt 5,
                 Cons ((PAs (PVar "n", "x"), None,
                        EBin (OpAdd, EVar "n", EVar "x")), Nil));
// e9: or-pattern — `match 2 with | 1 | 2 | 3 -> "low" | _ -> "high"` -> "low"
let e9 = EMatch (EInt 2,
                 Cons ((POr (POr (PInt 1, PInt 2), PInt 3), None,
                        EStr "low"),
                   Cons ((PWild, None, EStr "high"), Nil)));
// e10: guard — `match 7 with | n when n > 0 -> "pos" | _ -> "nonpos"` -> "pos"
let e10 = EMatch (EInt 7,
                  Cons ((PVar "n",
                         Some (ECmp (OpGt, EVar "n", EInt 0)),
                         EStr "pos"),
                    Cons ((PWild, None, EStr "nonpos"), Nil)));
// e11: nested constr — `Some (Some 1)` matched -> 1
let e11 = EMatch (EConstr ("Some", Some (EConstr ("Some", Some (EInt 1)))),
                  Cons ((PConstr ("Some", Some (PConstr ("Some", Some (PVar "n")))),
                         None, EVar "n"),
                    Cons ((PWild, None, EInt 0), Nil)));
// e12: closure that ignores its arg — `(fn _ -> 42) 99` -> 42
let e12 = EApp (EFun ("_u", None, EInt 42), EInt 99);

// === Stage 51b-2 demo data (let rec) =======================================
//
// e13: factorial — `let rec fact = fn n -> if n < 1 then 1 else n * fact (n - 1) in fact 5` -> 120
let fact_body =
  EFun ("n", None,
    EIf (ECmp (OpLt, EVar "n", EInt 1),
         EInt 1,
         EBin (OpMul, EVar "n",
               EApp (EVar "fact",
                     EBin (OpSub, EVar "n", EInt 1)))));
let e13 = ELetRec (Cons (("fact", fact_body), Nil),
                   EApp (EVar "fact", EInt 5));

// e14: mutual recursion — `let rec even = ... and odd = ... in even 10` -> true
let even_body =
  EFun ("n", None,
    EIf (ECmp (OpEq, EVar "n", EInt 0),
         EBool true,
         EApp (EVar "odd",
               EBin (OpSub, EVar "n", EInt 1))));
let odd_body =
  EFun ("n", None,
    EIf (ECmp (OpEq, EVar "n", EInt 0),
         EBool false,
         EApp (EVar "even",
               EBin (OpSub, EVar "n", EInt 1))));
let e14 = ELetRec (Cons (("even", even_body),
                     Cons (("odd", odd_body), Nil)),
                   EApp (EVar "even", EInt 10));

// e15: Fibonacci — `let rec fib = fn n -> if n < 2 then n else fib (n-1) + fib (n-2) in fib 8` -> 21
let fib_body =
  EFun ("n", None,
    EIf (ECmp (OpLt, EVar "n", EInt 2),
         EVar "n",
         EBin (OpAdd,
               EApp (EVar "fib", EBin (OpSub, EVar "n", EInt 1)),
               EApp (EVar "fib", EBin (OpSub, EVar "n", EInt 2)))));
let e15 = ELetRec (Cons (("fib", fib_body), Nil),
                   EApp (EVar "fib", EInt 8));

// e16: list sum — `let rec sum = fn xs -> match xs with | Nil -> 0 | Cons (h, t) -> h + sum t in sum (Cons(1, Cons(2, Cons(3, Nil))))`
let sum_body =
  EFun ("xs", None,
    EMatch (EVar "xs",
      Cons ((PConstr ("Nil", None), None, EInt 0),
        Cons ((PConstr ("Cons", Some (PTuple (Cons (PVar "h",
                                                Cons (PVar "t", Nil))))),
               None,
               EBin (OpAdd, EVar "h", EApp (EVar "sum", EVar "t"))),
          Nil))));
let cons_pair = fn (h: expr) -> fn (t: expr) ->
  EConstr ("Cons", Some (ETuple (Cons (h, Cons (t, Nil)))));
let nil_e = EConstr ("Nil", None);
let list_123 = cons_pair (EInt 1) (cons_pair (EInt 2) (cons_pair (EInt 3) nil_e));
let e16 = ELetRec (Cons (("sum", sum_body), Nil),
                   EApp (EVar "sum", list_123));

// === Stage 51c demos (list literal reconstruction) =========================

// e17: bare empty list -> "[]"
let e17 = nil_e;
// e18: bare list literal -> "[1, 2, 3]"
let e18 = list_123;
// e19: build a list with `let rec mklist = fn n -> if n < 1 then Nil
//      else Cons (n, mklist (n - 1)) in mklist 5` -> "[5, 4, 3, 2, 1]"
let mklist_body =
  EFun ("n", None,
    EIf (ECmp (OpLt, EVar "n", EInt 1),
         EConstr ("Nil", None),
         EConstr ("Cons",
           Some (ETuple (Cons (EVar "n",
                          Cons (EApp (EVar "mklist",
                                      EBin (OpSub, EVar "n", EInt 1)),
                            Nil)))))));
let e19 = ELetRec (Cons (("mklist", mklist_body), Nil),
                   EApp (EVar "mklist", EInt 5));
// e20: list reverse — `let rec rev_aux = fn xs -> fn acc -> match xs
//      with | Nil -> acc | Cons (h, t) -> rev_aux t (Cons (h, acc)) in
//      rev_aux [1, 2, 3] Nil` -> "[3, 2, 1]"
let cons_h_acc =
  EConstr ("Cons", Some (ETuple (Cons (EVar "h",
                              Cons (EVar "acc", Nil)))));
let rev_aux_body =
  EFun ("xs", None,
    EFun ("acc", None,
      EMatch (EVar "xs",
        Cons ((PConstr ("Nil", None), None, EVar "acc"),
          Cons ((PConstr ("Cons", Some (PTuple (Cons (PVar "h",
                                                Cons (PVar "t", Nil))))),
                 None,
                 EApp (EApp (EVar "rev_aux", EVar "t"), cons_h_acc)),
            Nil)))));
let e20 = ELetRec (Cons (("rev_aux", rev_aux_body), Nil),
                   EApp (EApp (EVar "rev_aux", list_123), nil_e));

// === Stage 51d demo data (records) =========================================
//
// e21: `Point { x = 1, y = 2 }` -> VRecord
let e21 = ERecordLit ("Point",
  Cons (("x", EInt 1), Cons (("y", EInt 2), Nil)));
// e22: field access — `(Point { x = 3, y = 4 }).x` -> 3
let e22 = EFieldGet (
  ERecordLit ("Point",
    Cons (("x", EInt 3), Cons (("y", EInt 4), Nil))),
  "x");
// e23: record update — `let p = Point { x = 0, y = 0 } in { p | x = 10 }`
//      -> Point { x = 10, y = 0 }
let e23 = ELet (PVar "p",
  ERecordLit ("Point",
    Cons (("x", EInt 0), Cons (("y", EInt 0), Nil))),
  ERecordUpdate (EVar "p", Cons (("x", EInt 10), Nil)));
// e24: pattern match — `match Point { x = 0, y = 5 } with
//      | Point { x = 0 } -> "on-y-axis" | _ -> "off-axis"`
let e24 = EMatch (
  ERecordLit ("Point",
    Cons (("x", EInt 0), Cons (("y", EInt 5), Nil))),
  Cons ((PRecord ("Point", Cons (("x", PInt 0), Nil)),
         None, EStr "on-y-axis"),
    Cons ((PWild, None, EStr "off-axis"), Nil)));
// e25: destructure in let — `let Point { x = a, y = b } = Point { x = 7, y = 8 }
//      in a + b` -> 15
let e25 = ELet (
  PRecord ("Point", Cons (("x", PVar "a"), Cons (("y", PVar "b"), Nil))),
  ERecordLit ("Point",
    Cons (("x", EInt 7), Cons (("y", EInt 8), Nil))),
  EBin (OpAdd, EVar "a", EVar "b"));

let _ = print "=== Stage 51a eval demos ===" in
let _ = print ("d1  (literal 42):       " ++ value_to_str (eval d1 empty_env)) in
let _ = print ("d2  (1 + 2):            " ++ value_to_str (eval d2 empty_env)) in
let _ = print ("d3  (3 * (4 + 5)):      " ++ value_to_str (eval d3 empty_env)) in
let _ = print ("d4  (if cmp lt):        " ++ value_to_str (eval d4 empty_env)) in
let _ = print ("d5  (-5):               " ++ value_to_str (eval d5 empty_env)) in
let _ = print ("d6  (true && false):    " ++ value_to_str (eval d6 empty_env)) in
let _ = print ("d7  (eq || false):      " ++ value_to_str (eval d7 empty_env)) in
let _ = print ("d8  (str concat):       " ++ value_to_str (eval d8 empty_env)) in
let _ = print ("d9  (env x+y, 10+20):   " ++ value_to_str (eval d9_expr env_xy)) in
let _ = print ("d10 (if x>0 ... else):  " ++ value_to_str (eval d10_expr env_neg)) in
let _ = print ("d11 (short-circuit):    " ++ value_to_str (eval d11 empty_env)) in
let _ = print "" in
let _ = print "=== Stage 51b-1 eval demos (closures + let + match) ===" in
let _ = print ("e1  (let x = 5 in x+1):       " ++ value_to_str (eval e1 empty_env)) in
let _ = print ("e2  ((fn x->x+1) 5):          " ++ value_to_str (eval e2 empty_env)) in
let _ = print ("e3  (closure capture):        " ++ value_to_str (eval e3 empty_env)) in
let _ = print ("e4  (inc (inc 10)):           " ++ value_to_str (eval e4 empty_env)) in
let _ = print ("e5  (match int):              " ++ value_to_str (eval e5 empty_env)) in
let _ = print ("e6  (let tuple destructure):  " ++ value_to_str (eval e6 empty_env)) in
let _ = print ("e7  (match Some/None):        " ++ value_to_str (eval e7 empty_env)) in
let _ = print ("e8  (as-pattern):             " ++ value_to_str (eval e8 empty_env)) in
let _ = print ("e9  (or-pattern):             " ++ value_to_str (eval e9 empty_env)) in
let _ = print ("e10 (guard):                  " ++ value_to_str (eval e10 empty_env)) in
let _ = print ("e11 (nested constr):          " ++ value_to_str (eval e11 empty_env)) in
let _ = print ("e12 (ignored arg):            " ++ value_to_str (eval e12 empty_env)) in
let _ = print "" in
let _ = print "=== Stage 51b-2 eval demos (let rec) ===" in
let _ = print ("e13 (factorial 5):            " ++ value_to_str (eval e13 empty_env)) in
let _ = print ("e14 (mutual even 10):         " ++ value_to_str (eval e14 empty_env)) in
let _ = print ("e15 (fib 8):                  " ++ value_to_str (eval e15 empty_env)) in
let _ = print ("e16 (list sum [1,2,3]):       " ++ value_to_str (eval e16 empty_env)) in
let _ = print "" in
let _ = print "=== Stage 51c eval demos (list literal reconstruction) ===" in
let _ = print ("e17 (empty list):             " ++ value_to_str (eval e17 empty_env)) in
let _ = print ("e18 (list [1,2,3]):           " ++ value_to_str (eval e18 empty_env)) in
let _ = print ("e19 (mklist 5):               " ++ value_to_str (eval e19 empty_env)) in
let _ = print ("e20 (rev [1,2,3]):            " ++ value_to_str (eval e20 empty_env)) in
let _ = print "" in
let _ = print "=== Stage 51d eval demos (records) ===" in
let _ = print ("e21 (record literal):         " ++ value_to_str (eval e21 empty_env)) in
let _ = print ("e22 (field access .x):        " ++ value_to_str (eval e22 empty_env)) in
let _ = print ("e23 (record update):          " ++ value_to_str (eval e23 empty_env)) in
let _ = print ("e24 (record pat match):       " ++ value_to_str (eval e24 empty_env)) in
let _ = print ("e25 (let record destructure): " ++ value_to_str (eval e25 empty_env)) in
let _ = print "" in
let _ = print "=== Stage 51e eval demos (parse + run_program) ===" in
// f1: simplest source -> value
let _ = print ("f1  (1 + 2 * 3):              " ++ value_to_str (parse_and_eval "1 + 2 * 3")) in
// f2: let + main
let _ = print ("f2  (let x = 5; x + 1):       " ++ value_to_str (parse_and_eval "let x = 5; x + 1")) in
// f3: factorial via let rec
let _ = print ("f3  (let rec fact ...):       " ++ value_to_str (parse_and_eval "let rec fact = fn n -> if n < 1 then 1 else n * fact (n - 1); fact 5")) in
// f4: variant type + match
let _ = print ("f4  (type opt + match):       " ++ value_to_str (parse_and_eval "type opt = | Just of int | Nothing; match Just (42) with | Just (n) -> n | Nothing -> 0")) in
// f5: list construction + sum
let _ = print ("f5  (list sum):               " ++ value_to_str (parse_and_eval "let rec sum = fn xs -> match xs with | Nil -> 0 | Cons (h, t) -> h + sum t; sum [1, 2, 3, 4]")) in
// f6: record literal + field
let _ = print ("f6  (record + field access):  " ++ value_to_str (parse_and_eval "type Point = \{ x: int, y: int }; let p = Point \{ x = 3, y = 4 }; p.x + p.y")) in
// f7: builtin call — `print "hello"` returns unit, but the side effect
//     should fire. The displayed value is `()`.
let _ = print "f7  (print \"hello\"):" in
let _ = print ("    [side effect] " ++ value_to_str (parse_and_eval "print \"hello\"")) in
// f8: show + str concat
let _ = print ("f8  (show + concat):          " ++ value_to_str (parse_and_eval "\"answer: \" ++ show 42")) in
0

// contrib/test/test.mere — minimal unit test framework for Mere
//
// A post-Phase-42 dogfood library. Namespaced as `module Test { ... }`.
// By using the (polymorphic) `show` builtin, a single `assert_eq` can
// compare int / str / bool / variant / tuple uniformly.
//
// Usage:
//   import "contrib/test/test.mere";
//   let s = Test.new_suite () in
//   let _ = Test.assert_eq s "1 + 1 = 2" 2 (1 + 1) in
//   let _ = Test.assert_eq s "hello"   "hi" ("h" ++ "i") in
//   let _ = Test.summary s in
//   Test.exit_status s
//
// Design:
//   - suite = (counters: Map[str, int], log: StrBuf)
//     - counters["pass"] / counters["fail"] hold the counts
//     - log is a string accumulating expected / actual from FAILs
//   - assert_eq compares with `show x == show y` (avoids polymorphic type compare)
//   - summary prints pass/fail/total, and prints the fail log if any
//   - exit_status returns 0 on all-pass, 1 if there is any fail
//     (intended for CI / shell pipelines)
//
// Limitations (MVP):
//   - No test grouping (describe/context)
//   - No parallel execution (Mere has no threads)
//   - No setup/teardown hooks (each test fn acquires resources per region)
//   - Exception catch goes through the `try_or` builtin — each assert does
//     not internally need try_or (the only Mere exception is `fail`; if
//     user code fails the test runner crashes too — a future option will
//     wrap with try_or and continue)
//
// Backend support: **diff = 0 across the 4 backends** interp / C / LLVM / Wasm
// (in Phase 43, a Map case was added to `ty_tag` in codegen_wasm.ml so that
// Map can be used as a carrier in closure env / tuple slots).

module Test {

let new_suite = fn () ->
  let counters = map_new () in
  let _ = map_set counters "pass" 0 in
  let _ = map_set counters "fail" 0 in
  let log = strbuf_new () in
  (counters, log);

// poly assert: stringify with `show` and compare. OK if expected and actual have the same type.
let assert_eq = fn suite -> fn (label: str) -> fn expected -> fn actual ->
  let (counters, log) = suite in
  let e = show expected in
  let a = show actual in
  if e == a then
    let _ = map_set counters "pass" (map_get counters "pass" + 1) in
    print ("  ok | " ++ label)
  else
    let _ = map_set counters "fail" (map_get counters "fail" + 1) in
    let _ = strbuf_push log ("FAIL | " ++ label ++ "\n") in
    let _ = strbuf_push log ("  expected: " ++ e ++ "\n") in
    let _ = strbuf_push log ("  actual:   " ++ a ++ "\n") in
    print ("FAIL | " ++ label);

// bool-true assertion — Phase 43 fixed DEFERRED §1.7 (multi-instantiation
// codegen), so we can now internally call assert_eq (the old inline
// implementation is removed, restoring brevity).
let assert_true = fn suite -> fn (label: str) -> fn (cond: bool) ->
  assert_eq suite label true cond;

let assert_false = fn suite -> fn (label: str) -> fn (cond: bool) ->
  assert_eq suite label false cond;

// Print pass/fail/total. If there are fails, emit the log.
let summary = fn suite ->
  let (counters, log) = suite in
  let pass = map_get counters "pass" in
  let fail = map_get counters "fail" in
  let total = pass + fail in
  let _ = print "" in
  let _ = print ("--- " ++ show pass ++ "/" ++ show total ++ " passed ---") in
  let logstr = strbuf_to_str log in
  if str_len logstr > 0 then print logstr else ();

// Exit code for CI: all pass = 0, any fail = 1
let exit_status = fn suite ->
  let (counters, _) = suite in
  if map_get counters "fail" == 0 then 0 else 1;

};   // end of `module Test`

// === Self-tests (outside the module, kept as a demo) ===

let _ = print "=== test framework demo ===";
let s = Test.new_suite ();

let _ = Test.assert_eq s "1 + 1 = 2" 2 (1 + 1);
let _ = Test.assert_eq s "string concat" "hi" ("h" ++ "i");
let _ = Test.assert_eq s "list length" 3 (list_len (Cons (1, Cons (2, Cons (3, Nil)))));
let _ = Test.assert_true s "5 > 3" (5 > 3);
let _ = Test.assert_false s "5 < 3" (5 < 3);

// Intentionally fail one case (to demonstrate assert_eq behavior)
let _ = Test.assert_eq s "(intentional fail) 2 = 3" 2 3;

let _ = Test.summary s;
Test.exit_status s
